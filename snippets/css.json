{
    "@container": {
        "prefix": "@c",
        "body": "@container (${1:query})$2 {\n  $0\n}"
    },
    "@containernamed": {
        "prefix": "@cn",
        "body": "@container ${1:name} (${2:query})$3 {\n  $0\n}"
    },
    "@containerscrollstate": {
        "prefix": "@css",
        "body": "@container  scroll-state(scrollable: ${1:top})$2 {\n  $0\n}"
    },
    "@containernamedscrollstate": {
        "prefix": "@cnss",
        "body": "@container ${1:name} scroll-state(scrollable: ${2:top})$3 {\n  $0\n}"
    },
    "@containeranchor": {
        "prefix": "@ca",
        "body": "@container anchored(fallback: ${1:bottom})$2 {\n  $0\n}"
    },
    "@containernamedanchor": {
        "prefix": "@cna",
        "body": "@container ${1:name} anchored(fallback: ${2:bottom})$3 {\n  $0\n}"
    },
    "@counter-style": {
        "prefix": "@count",
        "body": "@counter-style ${1:name} {\n  $0\n}"
    },
    "@custom-media": {
        "prefix": "@cm",
        "body": "@custom-media --${1:name} (${2:query})$3;$0"
    },
    "@font-face": {
        "prefix": "@ff",
        "body": "@font-face {\n  font-family: \"${1:fontName}\";\n  src: url(\"${2:source}\")\n  $0\n}"
    },
    "@function": {
        "prefix": "@func",
        "body": "@function --${1:name} (${2:parameters}) returns <${3:type}> {\n  result: $0; \n}"
    },
    "@import": {
        "prefix": "@i",
        "body": "@import url(\"${1:href}\");$0"
    },
    "@import supports": {
        "prefix": "@is",
        "body": "@import url(\"${1:href}\") supports(${2:rule});$0"
    },
    "@import layer": {
        "prefix": "@il",
        "body": "@import url(\"${1:href}\") layer(${2:name});$0"
    },
    "@import layer supports": {
        "prefix": "@ils",
        "body": "@import url(\"${1:href}\") layer(${2:name}) supports(${3:rule});$0"
    },
    "@mixin": {
        "prefix": "@mix",
        "body": "@mixin --${1:name} {\n  $0\n}"
    },
    "@apply": {
        "prefix": "@a",
        "body": "@apply --$0;"
    },
    "@keyframes": {
        "prefix": "@k",
        "body": "@keyframes ${1:name} {\n  $0\n}"
    },
    "@media": {
        "prefix": "@m",
        "body": "@media (${1:query})$2 {\n  $0\n}"
    },
    "@mediascreen": {
        "prefix": "@ms",
        "body": "@media screen {\n  $0\n}"
    },
    "@mediascreenand": {
        "prefix": "@msa",
        "body": "@media screen and (${1:query})$2 {\n  $0\n}"
    },
    "@mediaprint": {
        "prefix": "@mp",
        "body": "@media print {\n  $0\n}"
    },
    "@mediaprintand": {
        "prefix": "@mpa",
        "body": "@media print and (${1:query})$2 {\n  $0\n}"
    },
    "@positiontry": {
        "prefix": "@pt",
        "body": "@position-try --${1:name} {\n  $0\n}"
    },
    "@property": {
        "prefix": "@p",
        "body": "@property --${1:name} {\n  syntax: \"${2:syntax}\";\n  inherits: true;\n  initial-value: $0;\n}"
    },
    "@scope": {
        "prefix": "@s",
        "body": "@scope (${1:selector}) {\n  $0\n}"
    },
    "@scopeto": {
        "prefix": "@st",
        "body": "@scope (${1:selector}) to (${2:selector}) {\n  $0\n}"
    },
    "@starting-style": {
        "prefix": "@ss",
        "body": "@starting-style {\n  $0\n}"
    }
}
